{
  "name": "pizza-restaurant-server",
  "version": "1.0.0",
  "description": "Real-time pizza restaurant management system - Server-side with Node.js, TypeScript, MongoDB, Socket.IO, and worker simulation",
  "main": "index.ts",
  "scripts": {
    "lint": "eslint src",
    "lint-staged": "lint-staged",
    "prettier-check": "prettier --check .",
    "prettier-fix": "prettier --write .",
    "start": "npm run dbm:up && tsc --project tsconfig.build.json && node dist/src/app.js",
    "dev": "nodemon src/app.ts",
    "kill": "taskkill -f -im node.exe"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/orassayag/pizza-restaurant.git"
  },
  "contributors": [
    {
      "name": "Or Assayag",
      "email": "orassayag@gmail.com",
      "url": "https://github.com/orassayag"
    }
  ],
  "keywords": [
    "pizza",
    "restaurant",
    "real-time",
    "socket.io",
    "mongodb",
    "typescript",
    "nodejs",
    "express",
    "worker-simulation",
    "order-management",
    "workflow-automation"
  ],
  "author": "Or Assayag",
  "license": "MIT",
  "dependencies": {
    "chance": "^1.1.11",
    "debug": "^4.3.4",
    "express": "^4.18.2",
    "mongoose": "^7.2.2",
    "nodemon": "2.0.22",
    "socket.io": "^4.6.2",
    "ts-node": "10.9.1",
    "typescript": "5.1.3",
    "winston": "^3.9.0"
  },
  "devDependencies": {
    "@types/chance": "^1.1.3",
    "@types/cors": "^2.8.13",
    "@types/debug": "^4.1.8",
    "@types/express": "^4.17.17",
    "@types/node": "^20.2.5",
    "@typescript-eslint/eslint-plugin": "5.59.8",
    "@typescript-eslint/parser": "5.59.8",
    "eslint": "8.42.0",
    "eslint-config-airbnb-typescript": "17.0.0",
    "eslint-config-prettier": "8.8.0",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-prettier": "4.2.1",
    "prettier": "2.8.8"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "npm run prettier:fix",
      "npm run lint",
      "git add"
    ]
  }
}